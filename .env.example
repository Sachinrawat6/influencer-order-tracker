# Frontend env vars. Copy to `.env.local` for dev, set in Netlify UI for prod.

# API base URL. Both forms work — api.js auto-appends `/api` if missing.
#   Production:   https://cutting-qrcode-api.qurvii.com
#   Staging:      https://staging-cutting-qrcode-api.qurvii.com
#   Local proxy:  (leave unset — vite.config.js proxies /api to staging)
VITE_API_BASE_URL=
